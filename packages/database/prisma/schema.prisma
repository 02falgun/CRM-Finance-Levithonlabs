datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id             String          @id @default(uuid())
  subdomain      String          @unique
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  companyProfile CompanyProfile?
  users          User[]
  roles          Role[]
  permissions    Permission[]
  customers      Customer[]
  leads          Lead[]
  quotations     Quotation[]
  invoices       Invoice[]
  taxes          Tax[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  settings       Setting[]
  reports        Report[]
}

model CompanyProfile {
  id        String    @id @default(uuid())
  tenantId  String    @unique
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  panNumber String    // Seller PAN in Nepal (9 digits)
  email     String?
  phone     String?
  address   String?
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String    @unique
  passwordHash String
  name         String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  roles        UserRole[]
  auditLogs    AuditLog[]

  @@index([tenantId])
}

model Role {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String           // e.g. "TENANT_ADMIN", "SALES_REPRESENTATIVE", "BILLING_MANAGER", "AUDITOR"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action      String           // e.g. "invoice:create", "invoice:void", "lead:write"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  roles       RolePermission[]

  @@unique([tenantId, action])
  @@index([tenantId])
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model Customer {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  panNumber String?   // Buyer PAN
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contacts   CustomerContact[]
  leads      Lead[]
  quotations Quotation[]
  invoices   Invoice[]

  @@index([tenantId])
}

model CustomerContact {
  id         String    @id @default(uuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  role       String?   // e.g. "Finance Head", "Manager"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([customerId])
}

model Lead {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String    // "NEW", "CONTACTED", "QUALIFIED", "PROPOSAL_SENT", "WON", "LOST"
  value       Decimal   @default(0.00) @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  activities  LeadActivity[]

  @@index([tenantId])
  @@index([customerId])
}

model LeadActivity {
  id          String    @id @default(uuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String    // "CALL", "EMAIL", "MEETING", "NOTE"
  note        String
  performedBy String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([leadId])
}

model Quotation {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quoteNumber  String
  status       String    @default("DRAFT") // DRAFT, SENT, APPROVED, REJECTED, EXPIRED
  validUntil   DateTime
  subTotal     Decimal   @db.Decimal(12, 2)
  taxAmount    Decimal   @db.Decimal(12, 2)
  totalAmount  Decimal   @db.Decimal(12, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  items        QuotationItem[]

  @@index([tenantId])
  @@index([customerId])
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalPrice  Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([quotationId])
}

model Invoice {
  id                    String    @id @default(uuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId            String
  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoiceNo             String    // Sequential (INV-YYYY-NNNN)
  convertedFromQuoteId  String?
  fiscalYear            String    // e.g. 2080/2081
  billDateAD    DateTime
  billDateBS    String
  subTotal      Decimal   @db.Decimal(12, 2)
  discount      Decimal   @default(0.00) @db.Decimal(12, 2)
  taxableAmt    Decimal   @db.Decimal(12, 2)
  vatAmount     Decimal   @db.Decimal(12, 2)
  nonTaxableAmt Decimal   @default(0.00) @db.Decimal(12, 2)
  totalAmount   Decimal   @db.Decimal(12, 2)
  status        String    // "DRAFT", "ISSUED", "PAID", "VOIDED"
  isPrinted     Boolean   @default(false)
  printedBy     String?
  printedTime   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  items         InvoiceItem[]
  payments      Payment[]
  ebills        Ebill[]
  creditNotes   CreditNote[]

  @@index([tenantId])
  @@index([customerId])
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0.00) @db.Decimal(12, 2)
  taxableAmt  Decimal   @db.Decimal(12, 2)
  vatAmount   Decimal   @db.Decimal(12, 2)
  totalPrice  Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([invoiceId])
}

model Payment {
  id          String    @id @default(uuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(12, 2)
  paymentMode String    // "CASH", "ESEWA", "KHALTI", "BANK_TRANSFER"
  referenceNo String?
  paidAt      DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([invoiceId])
}

model Tax {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String    // e.g. "VAT 13%", "Exempt"
  rate      Decimal   @db.Decimal(5, 2)
  isExempt  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

model Ebill {
  id           String    @id @default(uuid())
  invoiceId    String
  invoice      Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payloadSent  Json
  responseRecv Json?
  statusCode   Int?
  syncStatus   String    // "PENDING", "SUCCESS", "FAILED"
  verifiedHash String?
  syncTime     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([invoiceId])
}

model Notification {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String    // "EMAIL", "SMS"
  recipient String
  message   String
  status    String    // "SENT", "FAILED"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
}

model AuditLog {
  id         String    @id @default(uuid())
  tenantId   String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityName String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([tenantId])
  @@index([userId])
}

model Report {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  type       String    // "TAX", "SALES", "AUDIT"
  parameters Json?
  fileUrl    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([tenantId])
}

model Setting {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, key])
  @@index([tenantId])
}

model CreditNote {
  id             String      @id @default(uuid())
  invoiceId      String
  invoice        Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  creditNoteNo   String      // Format matching IRD rules
  reason         String
  refundAmount   Decimal     @db.Decimal(12, 2)
  returnDateAD   DateTime
  returnDateBS   String
  irdSyncStatus  String      @default("PENDING")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  @@index([invoiceId])
}
